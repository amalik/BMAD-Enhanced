# The "files" field in package.json whitelists: index.js, scripts/,
# _bmad/bme/_vortex/, and specific top-level docs. This .npmignore
# only needs to handle edge cases within those whitelisted directories.

# Development files
.git/
.github/
.vscode/
.idea/
*.log
*.tmp

# Test files (not in "files" whitelist, but belt-and-suspenders)
tests/
test/
*.test.js
*.spec.js

# OS files
.DS_Store
Thumbs.db

# Git files
.gitignore
.gitattributes

# Editor files
*.swp
*.swo
*~
*.tgz

# Claude / Quint config
.claude/
_quint/
